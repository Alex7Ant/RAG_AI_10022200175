# LLM provider: openai or ollama
LLM_PROVIDER=openai

# If LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# If LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
